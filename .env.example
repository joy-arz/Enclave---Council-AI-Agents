# Enclave - Environment Variables
# Rename this file to .env and fill in your keys.

# =============================================================================
# CLI BINARY MAPPING (for local CLI agents)
# These binaries are used by default. You can also specify API keys below
# to use cloud providers instead. Binary names: gemini, qwen, codex, claude, opencode
# =============================================================================
STRATEGIST_BINARY=gemini
CRITIC_BINARY=qwen
OPTIMIZER_BINARY=gemini
CONTRARIAN_BINARY=qwen
JUDGE_BINARY=gemini

# =============================================================================
# API KEYS (for direct LLM API access - optional, CLI binaries are used by default)
# Set the binary name to "openai", "anthropic", "minimax", or "openrouter" to use APIs
# =============================================================================
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.chat

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
DEBUG=true
PORT=8000
HOST=127.0.0.1

# =============================================================================
# AUTONOMOUS MODE
# When enabled, agents can modify files directly without approval
# =============================================================================
AUTONOMOUS_MODE=false

# =============================================================================
# SESSION DEFAULTS
# =============================================================================
MAX_ROUNDS=7
MAX_TOKENS_PER_AGENT=1000
DEFAULT_TEMPERATURE=0.7
